{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "Always use absolute paths when operating on files."
  ],
  "default_agent": "biz-dev",
  "command": {
    "hello": {
      "template": "echo 'Hello from Onebot! Your agent is ready.'",
      "description": "测试命令：向世界问好"
    }
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".json", ".md"]
    }
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "*.log"
    ]
  }
}